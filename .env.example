# Postgres connection string.
# Local dev (docker-compose): postgresql://postgres:postgres@127.0.0.1:5432/breach_portal
# Production (Supabase): use the SESSION-mode pooler URI (port 5432), NOT the
# transaction pooler (port 6543) — transaction mode breaks migrations/DDL.
# Example: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/breach_portal

# Used to encrypt JWT tokens. Generate with: openssl rand -hex 32
# Rotating this invalidates all active admin sessions.
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Cloudflare Turnstile (bot protection on the contact form).
# Create a widget at https://dash.cloudflare.com -> Turnstile.
# For local dev/CI you can use Cloudflare's official test keys:
#   site key  1x00000000000000000000AA / secret 1x0000000000000000000000000000000AA (always passes)
# If TURNSTILE_SECRET_KEY is unset, server-side verification is skipped (dev only).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend (transactional email: contact form notifications, password resets).
# If RESEND_API_KEY is unset, emails are logged to the console instead.
# EMAIL_FROM_ADDRESS must be on a domain you have verified in Resend; a
# free-mail address (e.g. proton.me) will not send. If unset, the seed falls
# back to the dedicated incident mailbox.
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=Incident Response Team

# Where contact form submission notifications are sent.
# Private — this address is never displayed on the public site.
# If unset, defaults to the dedicated incident mailbox.
ADMIN_NOTIFICATION_EMAIL=

# --- S3-compatible storage (Supabase Storage) ---
# The PUBLIC bucket serves site images and posted notices (Media collection).
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# PRIVATE bucket for documents uploaded via the "Request Information" page.
# MUST be a separate, non-public bucket — these are client-submitted documents
# that may contain personal information and are served only via short-lived
# signed URLs after admin-only access checks. If unset, file uploads on the
# Request Information page are rejected (text requests still work).
S3_PRIVATE_BUCKET=
